<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="8dp">

    <!-- ── 일반 상태: 카테고리 카드 + 네비게이션 ── -->
    <LinearLayout
        android:id="@+id/normal_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <!-- 카드 + 화살표 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 이전 화살표 -->
            <TextView
                android:id="@+id/btn_prev"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="‹"
                android:textSize="20sp"
                android:textColor="#8A8580"
                android:includeFontPadding="false"/>

            <!-- 카테고리 카드 (탭 = 타이머 시작) -->
            <LinearLayout
                android:id="@+id/category_card"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_card_bg_0"
                android:padding="8dp">

                <TextView
                    android:id="@+id/cat_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚"
                    android:textSize="22sp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/cat_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="카테고리"
                    android:textSize="11sp"
                    android:textColor="#2D2926"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/cat_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0m"
                    android:textSize="10sp"
                    android:textColor="#5C5652"
                    android:includeFontPadding="false"/>

            </LinearLayout>

            <!-- 다음 화살표 -->
            <TextView
                android:id="@+id/btn_next"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="›"
                android:textSize="20sp"
                android:textColor="#8A8580"
                android:includeFontPadding="false"/>

        </LinearLayout>

        <!-- 페이지 도트 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="16dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <TextView android:id="@+id/dot0" android:layout_width="12dp" android:layout_height="12dp" android:gravity="center" android:text="●" android:textSize="6sp" android:textColor="#5C5652"/>
            <TextView android:id="@+id/dot1" android:layout_width="12dp" android:layout_height="12dp" android:gravity="center" android:text="○" android:textSize="6sp" android:textColor="#B8B3AD"/>
            <TextView android:id="@+id/dot2" android:layout_width="12dp" android:layout_height="12dp" android:gravity="center" android:text="○" android:textSize="6sp" android:textColor="#B8B3AD"/>
            <TextView android:id="@+id/dot3" android:layout_width="12dp" android:layout_height="12dp" android:gravity="center" android:text="○" android:textSize="6sp" android:textColor="#B8B3AD"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ── 측정 중 상태 ── -->
    <LinearLayout
        android:id="@+id/measuring_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <!-- 측정 중 카드 -->
        <LinearLayout
            android:id="@+id/timer_card"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_card_bg_0"
            android:padding="8dp">

            <TextView
                android:id="@+id/timer_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱"
                android:textSize="18sp"
                android:includeFontPadding="false"/>

            <TextView
                android:id="@+id/timer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="측정 중"
                android:textSize="11sp"
                android:textColor="#2D2926"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:includeFontPadding="false"/>

            <TextView
                android:id="@+id/timer_start_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="오전 9:00"
                android:textSize="9sp"
                android:textColor="#5C5652"
                android:includeFontPadding="false"/>

        </LinearLayout>

        <!-- 버튼 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/btn_pause_resume"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="⏸"
                android:textSize="14sp"
                android:textColor="#2D2926"/>

            <TextView
                android:id="@+id/btn_complete"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="✓"
                android:textSize="14sp"
                android:textColor="#2D2926"/>

            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="✕"
                android:textSize="14sp"
                android:textColor="#8A8580"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
